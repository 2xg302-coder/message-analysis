# DeepSeek API Configuration
# Replace "your_api_key_here" with your actual DeepSeek API Key (starts with sk-...)
DEEPSEEK_API_KEY=your_api_key_here

# Optional: DeepSeek Base URL (defaults to official API if not set)
# If using official DeepSeek: https://api.deepseek.com
# If using SiliconFlow (硅基流动): https://api.siliconflow.cn/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
