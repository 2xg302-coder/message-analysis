# Main LLM Configuration (For Deep Analysis)
# Supports OpenRouter, DeepSeek, etc.
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.0-pro-exp-02-05

# Fast LLM Configuration (For Flash News/NER)
# Can be a local model (Ollama) or a cheaper cloud model
FAST_LLM_API_KEY=ollama,sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxx
FAST_LLM_BASE_URL=http://localhost:11434/v1,https://openrouter.ai/api/v1
FAST_LLM_MODEL=qwen3.5:latest,google/gemini-2.0-flash-exp
FAST_LLM_CONCURRENCY=4,2

# DeepSeek Configuration (Legacy)
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# API 认证 (可选)
# 如果取消注释并设置此值，API 访问将受到保护
# API_SECRET=your-secret-key-here
